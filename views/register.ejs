<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - GradSkills Workspace</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">GradSkills Workspace</div>
      <div class="auth-subtitle">Create your workplace account</div>
    </div>

    <% if (locals.error) { %>
      <div class="alert alert-danger">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <%= error %>
      </div>
    <% } %>

    <form action="/register" method="POST">
      <div class="form-group">
        <label for="name" class="form-label">Full Name</label>
        <input type="text" id="name" name="name" class="form-control" placeholder="John Doe" required>
      </div>

      <div class="form-group">
        <label for="email" class="form-label">Email Address</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="name@company.com" required>
      </div>

      <div class="form-group">
        <label for="password" class="form-label">Password</label>
        <input type="password" id="password" name="password" class="form-control" placeholder="Min. 6 characters" required>
      </div>

      <div class="form-group">
        <label for="dob" class="form-label">Date of Birth</label>
        <input type="date" id="dob" name="dob" class="form-control" required>
      </div>

      <div class="form-group">
        <label for="role" class="form-label">Workplace Role</label>
        <select id="role" name="role" class="form-control" style="background-color: var(--bg-tertiary);" required>
          <option value="intern">Intern / Employee</option>
          <option value="tl">Team Lead (TL)</option>
          <option value="founder">Founder (Admin)</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primary btn-full" style="margin-top: 1rem;">Create Account</button>
    </form>

    <div class="auth-footer-link">
      Already have an account? <a href="/login">Sign In</a>
    </div>
  </div>
</body>
</html>
