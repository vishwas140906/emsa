<%- include('partials/header') %>

<style>
  /* ===== ENTERPRISE MNC UI OVERRIDES ===== */
  body {
    --ent-bg: #f9fafb;
    --ent-card: #ffffff;
    --ent-border: #e5e7eb;
    --ent-text-primary: #111827;
    --ent-text-secondary: #6b7280;
    --ent-primary: #0f172a;
    --ent-primary-hover: #334155;
    --ent-success: #16a34a;
    --ent-danger: #dc2626;
    --ent-warning: #ea580c;
    --ent-radius: 8px;
    
    background-color: var(--ent-bg) !important;
    color: var(--ent-text-primary) !important;
    -webkit-font-smoothing: antialiased;
  }
  
  h1, h2, h3, h4, h5, h6 { letter-spacing: -0.01em; color: var(--ent-text-primary) !important; }

  header { background: #ffffff !important; border-bottom: 1px solid var(--ent-border) !important; box-shadow: none !important; }
  .logo { -webkit-text-fill-color: var(--ent-text-primary) !important; color: var(--ent-text-primary) !important; }
  .user-profile div { color: var(--ent-text-primary) !important; }
  footer { background: #ffffff !important; border-top: 1px solid var(--ent-border) !important; color: var(--ent-text-secondary) !important; }

  main.container { padding: 0 !important; margin: 0 !important; max-width: none !important; }
  
  .workspace-layout {
    max-width: 1200px; margin: 2rem auto; padding: 0 1.5rem;
  }
  @media (max-width: 900px) {
    .workspace-layout { margin: 1rem auto; padding: 0 1rem; }
  }

  /* Enterprise Card */
  .ent-card { background: var(--ent-card); border: 1px solid var(--ent-border); border-radius: var(--ent-radius); box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); margin-bottom: 1.5rem; overflow: hidden; }
  .ent-card-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--ent-border); display: flex; justify-content: space-between; align-items: center; background: #ffffff; }
  .ent-card-title { font-size: 1rem; font-weight: 600; margin: 0; display: flex; flex-direction: column; }
  .ent-card-title span { font-size: 0.75rem; font-weight: 500; color: var(--ent-text-secondary); margin-top: 2px;}
  .ent-card-body { padding: 1.5rem; }
  
  /* Tabs */
  .ent-tabs {
    display: flex; gap: 1rem; border-bottom: 1px solid var(--ent-border); margin-bottom: 1.5rem; overflow-x: auto;
    -webkit-overflow-scrolling: touch; scrollbar-width: none;
  }
  .ent-tabs::-webkit-scrollbar { display: none; }
  .ent-tab {
    padding: 0.75rem 0.5rem; color: var(--ent-text-secondary); font-size: 0.875rem; font-weight: 500;
    text-decoration: none; border-bottom: 2px solid transparent; white-space: nowrap; transition: color 0.2s;
  }
  .ent-tab:hover { color: var(--ent-text-primary); }
  .ent-tab.active { color: var(--ent-primary); border-bottom-color: var(--ent-primary); font-weight: 600;}

  /* Page Header */
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.5rem; font-weight: 600; margin-bottom: 0.25rem; }
  .page-header p { font-size: 0.875rem; color: var(--ent-text-secondary); margin: 0; }

  /* Buttons */
  .btn-ent { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.5rem 1rem; font-size: 0.875rem; font-weight: 500; border-radius: 6px; border: 1px solid transparent; cursor: pointer; transition: all 0.15s ease-in-out; }
  .btn-ent-primary { background: var(--ent-primary); color: #ffffff !important; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
  .btn-ent-primary:hover { background: var(--ent-primary-hover); }
  .btn-ent-success { background: var(--ent-success); color: #ffffff !important; }
  .btn-ent-danger { background: var(--ent-danger); color: #ffffff !important; }
  .btn-ent-outline { background: #ffffff; border: 1px solid #d1d5db; color: var(--ent-text-primary); }
  .btn-ent-outline:hover { background: #f9fafb; }
  .btn-sm { padding: 0.25rem 0.6rem; font-size: 0.75rem; }
  .btn-full { width: 100%; }

  /* Forms & Inputs */
  .ent-label { display: block; font-size: 0.875rem; font-weight: 500; color: #374151; margin-bottom: 0.375rem; }
  .ent-input { width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: 0.875rem; background: #ffffff; transition: border-color 0.15s; font-family: inherit;}
  .ent-input:focus { outline: none; border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1); }
  
  /* Badges */
  .ent-badge { display: inline-flex; align-items: center; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 500; }
  .badge-gray { background: #f3f4f6; color: #374151 !important; }
  .badge-green { background: #dcfce7; color: #166534 !important; }
  .badge-red { background: #fee2e2; color: #991b1b !important; }
  .badge-amber { background: #ffedd5; color: #9a3412 !important; }
  .badge-blue { background: #dbeafe; color: #1e40af !important; }

  /* Tables */
  .ent-table-wrapper { overflow-x: auto; margin: -1.5rem; margin-top: 0; }
  .ent-table { width: 100%; border-collapse: collapse; text-align: left; }
  .ent-table th { padding: 0.75rem 1.5rem; font-size: 0.75rem; font-weight: 600; color: var(--ent-text-secondary); border-bottom: 1px solid var(--ent-border); background: #f9fafb; text-transform: uppercase;}
  .ent-table td { padding: 1rem 1.5rem; font-size: 0.875rem; border-bottom: 1px solid var(--ent-border); vertical-align: top;}
  .ent-table tr:last-child td { border-bottom: none; }

  /* Grids */
  .split-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem; align-items: start; }
  @media (max-width: 900px) { .split-grid { grid-template-columns: 1fr; } }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }

  /* Lists */
  .ent-list-item { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid var(--ent-border); }
  .ent-list-item:last-child { border-bottom: none; }
  
  /* Modal */
  .ent-modal { display: none; position: fixed; inset: 0; z-index: 1000; align-items: center; justify-content: center; background: rgba(0,0,0,0.5); padding: 1rem;}
  .ent-modal.show { display: flex; }
  .ent-modal-content { background: #fff; width: 100%; max-width: 500px; border-radius: var(--ent-radius); box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); overflow: hidden; }
  .ent-modal-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--ent-border); display: flex; justify-content: space-between; align-items: center;}
  .ent-modal-body { padding: 1.5rem; }

  /* Calendar */
  .ent-calendar { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; background: var(--ent-border); border: 1px solid var(--ent-border); border-radius: 6px; overflow: hidden; }
  .ent-cal-header { background: #f9fafb; padding: 0.5rem 0; text-align: center; font-size: 0.75rem; font-weight: 600; color: var(--ent-text-secondary); }
  .ent-cal-day { background: #ffffff; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 500; color: var(--ent-text-primary); position: relative;}
  .ent-cal-day.empty { background: #f9fafb; }
  .ent-cal-day.blocked { background: #e5e7eb; color: #9ca3af !important; cursor: not-allowed; }
  .ent-cal-day.present { background: #dcfce7; color: #166534 !important; font-weight: 600;}
  .ent-cal-day.absent { background: #fee2e2; color: #991b1b !important; font-weight: 600;}
  .ent-cal-day.half_day { background: #fef3c7; color: #92400e !important; font-weight: 600;}
  .ent-cal-day.leave { background: #fee2e2; color: #991b1b !important; font-weight: 600;}
  .ent-cal-day.holiday { color: #9ca3af !important; }
  .ent-cal-day.warning { background: #ffedd5; color: #9a3412 !important; font-weight: 600;}
  
  /* Alerts */
  .ent-alert { padding: 0.75rem 1rem; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.875rem; font-weight: 500; display: flex; align-items: center; gap: 0.5rem; }
  .ent-alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534 !important; }
  .ent-alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b !important; }
</style>

<div class="workspace-layout">
  <div class="page-header">
    <h1>Management Console</h1>
    <p>Track employee streaks, monitor punches, assign tasks, and review warnings.</p>
  </div>

  <% if (locals.success) { %>
    <div class="ent-alert ent-alert-success">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
      <%= success %>
    </div>
  <% } %>
  <% if (locals.error) { %>
    <div class="ent-alert ent-alert-error">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
      <%= error %>
    </div>
  <% } %>

  <nav class="ent-tabs">
    <a href="/tl/dashboard?tab=presence" class="ent-tab <%= activeTab === 'presence' ? 'active' : '' %>">Today's Presence</a>
    <a href="/tl/dashboard?tab=tasks" class="ent-tab <%= activeTab === 'tasks' ? 'active' : '' %>">Task Logs</a>
    <a href="/tl/dashboard?tab=streaks" class="ent-tab <%= activeTab === 'streaks' ? 'active' : '' %>">Employee Streaks</a>
    <a href="/tl/dashboard?tab=reminders" class="ent-tab <%= activeTab === 'reminders' ? 'active' : '' %>">Warnings & Reminders</a>
    <a href="/tl/dashboard?tab=team" class="ent-tab <%= activeTab === 'team' ? 'active' : '' %>">Team Management</a>
  </nav>

  <!-- ================= TAB: TODAY'S PRESENCE ================= -->
  <% if (activeTab === 'presence') { %>
    <div class="split-grid">
      <div>
        <div class="ent-card">
          <div class="ent-card-header">
            <h2 class="ent-card-title" style="display: flex; justify-content: space-between; align-items: center;">
              <span>Employee Monitor <span style="font-size: 0.75rem; color: var(--ent-text-secondary); font-weight: 500; margin-left: 0.5rem;">Daily logs for <%= new Date().toLocaleDateString('en-US', {month: 'short', day: 'numeric'}) %></span></span>
              <a href="/tl/export-attendance" class="btn-ent btn-ent-outline" style="font-size: 0.75rem; padding: 0.25rem 0.75rem;">Export to Excel</a>
            </h2>
          </div>
          <div class="ent-card-body">
            <% if (activities.length === 0) { %>
              <div style="text-align: center; color: var(--ent-text-secondary); padding: 2rem 0; font-size: 0.875rem;">No employees have punched in today.</div>
            <% } else { %>
              <div class="cards-grid" style="grid-template-columns: 1fr;">
                <% activities.forEach(act => { %>
                  <div style="border: 1px solid var(--ent-border); border-radius: 6px; padding: 1.25rem; <%= act.status === 'absent' ? 'background: #f9fafb; opacity: 0.7;' : '' %>">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 1rem; border-bottom: 1px solid var(--ent-border); padding-bottom: 0.75rem;">
                      <div>
                        <div style="font-weight: 600; font-size: 1rem;"><%= act.name %></div>
                        <div style="font-size: 0.75rem; color: var(--ent-text-secondary);"><%= act.email %></div>
                      </div>
                      <div>
                        <% if (act.status === 'present') { %>
                          <span class="ent-badge badge-green">Completed</span>
                        <% } else if (act.status === 'absent') { %>
                          <span class="ent-badge badge-red">Absent</span>
                        <% } else if (act.status === 'half_day') { %>
                          <span class="ent-badge badge-amber">Half Day</span>
                        <% } else if (act.status === 'leave') { %>
                          <span class="ent-badge badge-red">Leave</span>
                        <% } else { %>
                          <span class="ent-badge badge-blue">Active Session</span>
                        <% } %>
                      </div>
                    </div>
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; font-size: 0.875rem; margin-bottom: 1rem;">
                      <div>
                        <span style="color: var(--ent-text-secondary); display: block; font-size: 0.75rem;">Punch In</span>
                        <%= act.punch_in_time ? new Date(act.punch_in_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', timeZone: 'Asia/Kolkata'}) : 'N/A' %>
                      </div>
                      <div>
                        <span style="color: var(--ent-text-secondary); display: block; font-size: 0.75rem;">Punch Out</span>
                        <%= act.punch_out_time ? new Date(act.punch_out_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', timeZone: 'Asia/Kolkata'}) : '...' %>
                      </div>
                      <div>
                        <span style="color: var(--ent-text-secondary); display: block; font-size: 0.75rem;">Hours</span>
                        <%= act.hours_worked ? parseFloat(act.hours_worked).toFixed(2) : '-' %>
                      </div>
                      <% if (act.punch_in_latitude) { %>
                        <div style="grid-column: 1 / -1;">
                          <span style="color: var(--ent-text-secondary); display: block; font-size: 0.75rem;">Location</span>
                          <a href="https://www.openstreetmap.org/?mlat=<%= act.punch_in_latitude %>&mlon=<%= act.punch_in_longitude %>" target="_blank" style="color: var(--ent-primary); text-decoration: underline;">
                            <%= Number(act.punch_in_latitude).toFixed(4) %>, <%= Number(act.punch_in_longitude).toFixed(4) %>
                          </a>
                        </div>
                      <% } %>
                    </div>

                    <% if (act.punch_in_photo) { %>
                      <div style="margin-bottom: 1rem;">
                        <img src="/uploads/punches/<%= act.punch_in_photo %>" style="width: 100px; height: 100px; object-fit: cover; border-radius: 4px; border: 1px solid var(--ent-border);" alt="Punch-In">
                      </div>
                    <% } %>

                    <!-- Tasks -->
                    <div style="font-size: 0.875rem;">
                      <span style="color: var(--ent-text-secondary); display: block; font-size: 0.75rem; margin-bottom: 0.25rem;">Tasks Checklist</span>
                      <% let empTasks = employeeTasks[act.user_id] || []; %>
                      <% if (empTasks.length === 0) { %>
                        <div style="color: var(--ent-text-secondary);">No tasks assigned.</div>
                      <% } else { %>
                        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                          <% empTasks.forEach(task => { %>
                            <div style="display: flex; align-items: center; gap: 0.5rem; color: <%= task.status === 'completed' ? 'var(--ent-text-secondary)' : 'inherit' %>; text-decoration: <%= task.status === 'completed' ? 'line-through' : 'none' %>;">
                              <span style="color: <%= task.status === 'completed' ? 'var(--ent-success)' : 'var(--ent-danger)' %>; font-size: 1rem;">
                                <%= task.status === 'completed' ? '✓' : '✗' %>
                              </span>
                              <%= task.task_description %>
                            </div>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>

                    <% if (act.incomplete_reason) { %>
                      <div style="margin-top: 1rem; padding: 0.75rem; background: #fef2f2; border-left: 2px solid var(--ent-danger); font-size: 0.875rem;">
                        <strong style="color: var(--ent-danger); display: block; font-size: 0.75rem;">Roadblock Note</strong>
                        <%= act.incomplete_reason %>
                      </div>
                    <% } %>
                    <% if (act.admin_notes) { %>
                      <div style="margin-top: 1rem; padding: 0.75rem; background: #f3f4f6; border-left: 2px solid var(--ent-primary); font-size: 0.875rem;">
                        <strong style="color: var(--ent-primary); display: block; font-size: 0.75rem;">Admin Override</strong>
                        <%= act.admin_notes %>
                      </div>
                    <% } %>

                    <% if (act.status !== 'absent') { %>
                      <div style="margin-top: 1.25rem; border-top: 1px solid var(--ent-border); padding-top: 1rem;">
                        <button onclick="openOverrideModal('<%= act.attendance_id %>', '<%= act.name %>')" class="btn-ent btn-ent-outline btn-sm">
                          Invalidate & Mark Absent
                        </button>
                      </div>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
      
      <!-- Right Col -->
      <div>
        <div class="ent-card">
          <div class="ent-card-header">
            <h2 class="ent-card-title">Assign Tasks <span>Distribute daily assignments</span></h2>
          </div>
          <div class="ent-card-body">
            <form action="/tl/assign-task" method="POST">
              <div class="ent-label">Assign To</div>
              <div style="border: 1px solid var(--ent-border); border-radius: 6px; max-height: 200px; overflow-y: auto; padding: 0.5rem; margin-bottom: 1rem;">
                <% if (interns.length === 0) { %>
                  <div style="font-size: 0.875rem; color: var(--ent-text-secondary); text-align: center; padding: 1rem;">No interns available</div>
                <% } else { %>
                  <% interns.forEach(intern => { %>
                    <label style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem; cursor: pointer;">
                      <input type="checkbox" name="assignees[]" value="<%= intern.id %>" style="accent-color: var(--ent-primary);">
                      <span style="font-size: 0.875rem;"><%= intern.name %></span>
                    </label>
                  <% }) %>
                <% } %>
              </div>

              <div class="ent-label">Task Description</div>
              <textarea name="task_description" class="ent-input" rows="3" required style="margin-bottom: 1rem;"></textarea>

              <div class="ent-label">Target Date</div>
              <input type="date" name="assigned_date" class="ent-input" value="<%= new Date().toISOString().split('T')[0] %>" required style="margin-bottom: 1.5rem;">

              <button type="submit" class="btn-ent btn-ent-primary btn-full" <%= interns.length === 0 ? 'disabled' : '' %>>Distribute Task</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <!-- ================= TAB: TASK HISTORY ================= -->
  <% if (activeTab === 'tasks') { %>
    <div class="ent-card">
      <div class="ent-card-header">
        <h2 class="ent-card-title">Task History <span>Consolidated view of all assignments</span></h2>
      </div>
      <div class="ent-card-body" style="padding: 0;">
        <% if (tasksList.length === 0) { %>
          <div style="padding: 2rem; text-align: center; color: var(--ent-text-secondary); font-size: 0.875rem;">No tasks recorded.</div>
        <% } else { %>
          <div class="ent-table-wrapper">
            <table class="ent-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Assignee</th>
                  <th>Task</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% tasksList.forEach(task => { %>
                  <tr>
                    <td style="white-space: nowrap;"><%= new Date(task.assigned_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                    <td>
                      <div style="font-weight: 500;"><%= task.assignee_name %></div>
                      <div style="font-size: 0.75rem; color: var(--ent-text-secondary);"><%= task.assignee_email %></div>
                    </td>
                    <td style="max-width: 300px;"><%= task.task_description %></td>
                    <td>
                      <span class="ent-badge <%= task.status === 'completed' ? 'badge-green' : 'badge-amber' %>"><%= task.status %></span>
                    </td>
                    <td>
                      <form action="/tl/delete-task" method="POST" onsubmit="return confirm('Delete task?');">
                        <input type="hidden" name="task_id" value="<%= task.id %>">
                        <button type="submit" class="btn-ent btn-ent-outline btn-sm" style="color: var(--ent-danger);">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- ================= TAB: EMPLOYEE STREAKS ================= -->
  <% if (activeTab === 'streaks') { %>
    <div class="split-grid" style="grid-template-columns: 1fr 2fr;">
      <div>
        <div class="ent-card">
          <div class="ent-card-header"><h2 class="ent-card-title">Employees</h2></div>
          <div class="ent-card-body" style="padding: 0;">
            <% if (interns.length === 0) { %>
              <div style="padding: 1.5rem; text-align: center; font-size: 0.875rem; color: var(--ent-text-secondary);">No employees found.</div>
            <% } else { %>
              <% interns.forEach(intern => { %>
                <a href="/tl/dashboard?tab=streaks&intern_id=<%= intern.id %>" style="display: block; padding: 1rem 1.5rem; text-decoration: none; border-bottom: 1px solid var(--ent-border); background: <%= selectedInternId === intern.id ? '#f3f4f6' : '#fff' %>; color: var(--ent-text-primary); font-size: 0.875rem; font-weight: 500; transition: background 0.2s;">
                  <%= intern.name %>
                </a>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>
      
      <div>
        <div class="ent-card">
          <% if (!selectedInternId) { %>
            <div style="padding: 3rem; text-align: center; color: var(--ent-text-secondary); font-size: 0.875rem;">Select an employee to view their attendance history.</div>
          <% } else { 
            const activeIntern = interns.find(i => i.id === selectedInternId);
          %>
            <div class="ent-card-header">
              <h2 class="ent-card-title"><%= activeIntern ? activeIntern.name : 'History' %> <span>Current Streak: <%= selectedInternStreak %> Days</span></h2>
            </div>
            <div class="ent-card-body">
              <div class="ent-calendar">
                <div class="ent-cal-header">M</div><div class="ent-cal-header">T</div><div class="ent-cal-header">W</div>
                <div class="ent-cal-header">T</div><div class="ent-cal-header">F</div><div class="ent-cal-header">S</div><div class="ent-cal-header">S</div>
                
                <% selectedInternCalendar.forEach(cell => { %>
                  <% 
                    let cls = 'empty';
                    if (cell.type !== 'empty') {
                      if (cell.type === 'future') cls = 'empty';
                      else if (cell.type === 'blocked') cls = 'blocked';
                      else if (cell.type === 'holiday') cls = 'holiday';
                      else if (cell.type === 'pending_punchin') cls = 'empty';
                      else if (cell.type === 'unpunched_past') cls = 'absent';
                      else if (cell.type === 'attendance') {
                        if (cell.record.status === 'present') cls = 'present';
                        else if (cell.record.status === 'absent') cls = 'absent';
                        else if (cell.record.status === 'half_day') cls = 'half_day';
                        else if (cell.record.status === 'leave') cls = 'leave';
                        else cls = 'warning';
                      }
                    }
                  %>
                  <div class="ent-cal-day <%= cls %>" title="<%= cell.date %>">
                    <%= cell.type !== 'empty' ? cell.dayNum : '' %>
                  </div>
                <% }) %>
              </div>
              <div style="display: flex; gap: 1rem; margin-top: 1rem; font-size: 0.75rem; color: var(--ent-text-secondary); justify-content: center; flex-wrap: wrap;">
                <div style="display: flex; align-items: center; gap: 0.25rem;"><div style="width:8px; height:8px; border-radius:2px; background:var(--ent-success);"></div> Present</div>
                <div style="display: flex; align-items: center; gap: 0.25rem;"><div style="width:8px; height:8px; border-radius:2px; background:var(--ent-warning);"></div> Half Day</div>
                <div style="display: flex; align-items: center; gap: 0.25rem;"><div style="width:8px; height:8px; border-radius:2px; background:var(--ent-danger);"></div> Leave/Absent</div>
                <div style="display: flex; align-items: center; gap: 0.25rem;"><div style="width:8px; height:8px; border-radius:2px; background:#ffedd5;"></div> Active</div>
                <div style="display: flex; align-items: center; gap: 0.25rem;"><div style="width:8px; height:8px; border-radius:2px; background:#f9fafb; border:1px solid var(--ent-border);"></div> Unscheduled</div>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <!-- ================= TAB: WARNINGS & REMINDERS ================= -->
  <% if (activeTab === 'reminders') { %>
    <div class="split-grid" style="margin-bottom: 1.5rem;">
      <div class="ent-card">
        <div class="ent-card-header"><h2 class="ent-card-title">Missed Punch-In Today</h2></div>
        <div class="ent-card-body" style="padding: 0;">
          <% if (missedPunches.length === 0) { %>
            <div style="padding: 1.5rem; text-align: center; font-size: 0.875rem; color: var(--ent-success);">✔ All employees clocked in</div>
          <% } else { %>
            <% missedPunches.forEach(user => { %>
              <div class="ent-list-item" style="padding: 1rem 1.5rem;">
                <div>
                  <div style="font-weight: 500; font-size: 0.875rem;"><%= user.name %></div>
                  <div style="font-size: 0.75rem; color: var(--ent-text-secondary);"><%= user.email %></div>
                </div>
                <span class="ent-badge badge-red">Unpunched</span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
      <div class="ent-card">
        <div class="ent-card-header"><h2 class="ent-card-title">Active Sessions</h2></div>
        <div class="ent-card-body" style="padding: 0;">
          <% if (activeSessions.length === 0) { %>
            <div style="padding: 1.5rem; text-align: center; font-size: 0.875rem; color: var(--ent-text-secondary);">No active sessions</div>
          <% } else { %>
            <% activeSessions.forEach(session => { %>
              <div class="ent-list-item" style="padding: 1rem 1.5rem;">
                <div>
                  <div style="font-weight: 500; font-size: 0.875rem;"><%= session.name %></div>
                </div>
                <span class="ent-badge badge-blue">In: <%= new Date(session.punch_in_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', timeZone: 'Asia/Kolkata'}) %></span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Roadblocks -->
    <div class="ent-card">
      <div class="ent-card-header"><h2 class="ent-card-title">Employee Roadblocks <span>Logs of unfinished tasks</span></h2></div>
      <div class="ent-card-body" style="padding: 0;">
        <% if (roadblocks.length === 0) { %>
          <div style="padding: 2rem; text-align: center; font-size: 0.875rem; color: var(--ent-text-secondary);">No roadblocks recorded.</div>
        <% } else { %>
          <div class="ent-table-wrapper">
            <table class="ent-table">
              <thead><tr><th>Date</th><th>Employee</th><th>Roadblock Reason</th></tr></thead>
              <tbody>
                <% roadblocks.forEach(rb => { %>
                  <tr>
                    <td style="white-space: nowrap;"><%= new Date(rb.work_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                    <td><div style="font-weight: 500;"><%= rb.name %></div></td>
                    <td style="color: var(--ent-danger);"><%= rb.incomplete_reason %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Leave Requests -->
    <div class="ent-card">
      <div class="ent-card-header"><h2 class="ent-card-title">Leave Applications <span>Approve or reject leave</span></h2></div>
      <div class="ent-card-body" style="padding: 0;">
        <% 
          const pendingLeavesList = (pendingLeaves || []).filter(l => l.status === 'pending');
          const reviewedLeavesList = (pendingLeaves || []).filter(l => l.status !== 'pending');
        %>
        <% if (pendingLeavesList.length === 0 && reviewedLeavesList.length === 0) { %>
          <div style="padding: 2rem; text-align: center; font-size: 0.875rem; color: var(--ent-text-secondary);">No leave requests submitted.</div>
        <% } else { %>
          <div class="ent-table-wrapper">
            <table class="ent-table">
              <thead><tr><th>Employee</th><th>Date</th><th>Reason</th><th>Action / Status</th></tr></thead>
              <tbody id="leavesTableBody">
                <% pendingLeavesList.forEach(leave => { %>
                  <tr style="background: #fffbeb;" class="pending-leave-row" data-id="<%= leave.id %>">
                    <td><div style="font-weight: 500;"><%= leave.employee_name %></div></td>
                    <td style="white-space: nowrap;"><%= new Date(leave.leave_date).toLocaleDateString('en-US', {month: 'short', day: 'numeric'}) %></td>
                    <td><%= leave.reason %></td>
                    <td>
                      <div style="display: flex; gap: 0.5rem;">
                        <form action="/tl/review-leave" method="POST"><input type="hidden" name="leave_id" value="<%= leave.id %>"><input type="hidden" name="action" value="approved"><button type="submit" class="btn-ent btn-ent-success btn-sm">Approve</button></form>
                        <form action="/tl/review-leave" method="POST"><input type="hidden" name="leave_id" value="<%= leave.id %>"><input type="hidden" name="action" value="rejected"><button type="submit" class="btn-ent btn-ent-danger btn-sm">Reject</button></form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
                <% reviewedLeavesList.forEach(leave => { %>
                  <tr>
                    <td><div style="font-weight: 500;"><%= leave.employee_name %></div></td>
                    <td style="white-space: nowrap;"><%= new Date(leave.leave_date).toLocaleDateString('en-US', {month: 'short', day: 'numeric'}) %></td>
                    <td><%= leave.reason %></td>
                    <td><span class="ent-badge <%= leave.status === 'approved' ? 'badge-green' : 'badge-red' %>"><%= leave.status %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- ================= TAB: TEAM MANAGEMENT ================= -->
  <% if (activeTab === 'team') { %>
    <div class="ent-card">
      <div class="ent-card-header">
        <h2 class="ent-card-title">Team Management <span>Manage all employee accounts</span></h2>
        <button onclick="openAddEmployeeModal()" class="btn-ent btn-ent-primary" style="font-size: 0.875rem; padding: 0.5rem 1rem;">+ Add New Employee</button>
      </div>
      <div class="ent-card-body" style="padding: 0;">
        <% if (interns.length === 0) { %>
          <div style="padding: 2rem; text-align: center; color: var(--ent-text-secondary); font-size: 0.875rem;">No employees registered yet.</div>
        <% } else { %>
          <div class="ent-table-wrapper">
            <table class="ent-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Date of Birth</th>
                  <th>Joined Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% interns.forEach(intern => { %>
                  <tr>
                    <td><div style="font-weight: 500;"><%= intern.name %></div></td>
                    <td><%= intern.email %></td>
                    <td><%= new Date(intern.dob).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                    <td><%= intern.onboarding_date ? new Date(intern.onboarding_date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'N/A' %></td>
                    <td>
                      <form action="/tl/remove-employee" method="POST" onsubmit="return confirm('Are you sure you want to completely remove this employee? This will also remove their tasks and attendance logs.');">
                        <input type="hidden" name="employee_id" value="<%= intern.id %>">
                        <button type="submit" class="btn-ent btn-ent-outline btn-sm" style="color: var(--ent-danger); border-color: #fecaca;">Remove</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<!-- OVERRIDE ATTENDANCE MODAL -->
<div id="overrideModal" class="ent-modal">
  <div class="ent-modal-content">
    <div class="ent-modal-header">
      <h2 class="ent-card-title" style="font-size: 1.125rem;">Invalidate Attendance</h2>
      <button type="button" onclick="closeOverrideModal()" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:var(--ent-text-secondary);">&times;</button>
    </div>
    <form action="/tl/update-attendance" method="POST">
      <div class="ent-modal-body">
        <input type="hidden" id="overrideAttendanceId" name="attendance_id">
        <p style="font-size: 0.875rem; color: var(--ent-text-secondary); margin-bottom: 1.25rem;">
          You are changing <strong id="overrideEmployeeName" style="color: var(--ent-text-primary);"></strong>'s attendance to 
          <strong style="color: var(--ent-danger);">ABSENT</strong>.
        </p>
        <div class="ent-label">Reason / Feedback Notes</div>
        <textarea id="admin_notes" name="admin_notes" class="ent-input" rows="3" required></textarea>
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
          <button type="button" onclick="closeOverrideModal()" class="btn-ent btn-ent-outline" style="flex: 1;">Cancel</button>
          <button type="submit" class="btn-ent btn-ent-danger" style="flex: 1;">Confirm Absent Override</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- ADD EMPLOYEE MODAL -->
<div id="addEmployeeModal" class="ent-modal">
  <div class="ent-modal-content">
    <div class="ent-modal-header">
      <h2 class="ent-card-title" style="font-size: 1.125rem;">Add New Employee</h2>
      <button type="button" onclick="closeAddEmployeeModal()" style="background:none; border:none; font-size:1.5rem; cursor:pointer; color:var(--ent-text-secondary);">&times;</button>
    </div>
    <form action="/tl/add-employee" method="POST">
      <div class="ent-modal-body">
        <div style="margin-bottom: 1rem;">
          <label class="ent-label">Full Name</label>
          <input type="text" name="name" class="ent-input" required>
        </div>
        <div style="margin-bottom: 1rem;">
          <label class="ent-label">Email Address</label>
          <input type="email" name="email" class="ent-input" required>
        </div>
        <div style="margin-bottom: 1rem;">
          <label class="ent-label">Password</label>
          <input type="password" name="password" class="ent-input" required>
        </div>
        <div style="margin-bottom: 1.5rem;">
          <label class="ent-label">Date of Birth</label>
          <input type="date" name="dob" class="ent-input" required>
        </div>
        <div style="margin-bottom: 1.5rem;">
          <label class="ent-label">Onboarding Date</label>
          <input type="date" name="onboarding_date" class="ent-input" required>
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
          <button type="button" onclick="closeAddEmployeeModal()" class="btn-ent btn-ent-outline" style="flex: 1;">Cancel</button>
          <button type="submit" class="btn-ent btn-ent-primary" style="flex: 1;">Add Employee</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
  function openOverrideModal(attendanceId, name) {
    document.getElementById('overrideAttendanceId').value = attendanceId;
    document.getElementById('overrideEmployeeName').innerText = name;
    document.getElementById('overrideModal').classList.add('show');
  }
  function closeOverrideModal() {
    document.getElementById('overrideModal').classList.remove('show');
  }

  function openAddEmployeeModal() {
    document.getElementById('addEmployeeModal').classList.add('show');
  }
  function closeAddEmployeeModal() {
    document.getElementById('addEmployeeModal').classList.remove('show');
  }

  window.onclick = function(event) {
    const overrideModal = document.getElementById('overrideModal');
    const addEmployeeModal = document.getElementById('addEmployeeModal');
    if (event.target == overrideModal) { closeOverrideModal(); }
    if (event.target == addEmployeeModal) { closeAddEmployeeModal(); }
  }

  // Real-time Leave Requests Polling
  let knownPendingCount = <%= typeof pendingLeavesList !== 'undefined' ? pendingLeavesList.length : 0 %>;
  
  setInterval(async () => {
    try {
      const res = await fetch('/tl/api/leaves');
      const data = await res.json();
      if (data.success && data.pendingLeaves) {
        const currentPendingCount = data.pendingLeaves.length;
        
        // If a new leave request arrived
        if (currentPendingCount > knownPendingCount) {
          knownPendingCount = currentPendingCount;
          
          // If we are on the reminders tab, dynamically update the table
          const tbody = document.getElementById('leavesTableBody');
          if (tbody) {
            // Re-render pending leaves at the top
            let newRows = '';
            data.pendingLeaves.forEach(leave => {
              const d = new Date(leave.leave_date).toLocaleDateString('en-US', {month: 'short', day: 'numeric'});
              newRows += `
                <tr style="background: #fffbeb;" class="pending-leave-row" data-id="${leave.id}">
                  <td><div style="font-weight: 500;">${leave.employee_name}</div></td>
                  <td style="white-space: nowrap;">${d}</td>
                  <td>${leave.reason}</td>
                  <td>
                    <div style="display: flex; gap: 0.5rem;">
                      <form action="/tl/review-leave" method="POST"><input type="hidden" name="leave_id" value="${leave.id}"><input type="hidden" name="action" value="approved"><button type="submit" class="btn-ent btn-ent-success btn-sm">Approve</button></form>
                      <form action="/tl/review-leave" method="POST"><input type="hidden" name="leave_id" value="${leave.id}"><input type="hidden" name="action" value="rejected"><button type="submit" class="btn-ent btn-ent-danger btn-sm">Reject</button></form>
                    </div>
                  </td>
                </tr>
              `;
            });
            
            // Remove old pending rows
            document.querySelectorAll('.pending-leave-row').forEach(row => row.remove());
            
            // Insert new rows at the top
            tbody.insertAdjacentHTML('afterbegin', newRows);
            
            // Optionally alert the TL
            // alert('New Leave Request Received!');
          } else {
            // Not on reminders tab, show a small visual indicator or alert
            const tabEl = document.querySelector('a[href="/tl/dashboard?tab=reminders"]');
            if(tabEl && !tabEl.innerText.includes('New')) {
              tabEl.innerHTML += ' <span style="background:var(--ent-danger); color:white; padding:2px 6px; border-radius:10px; font-size:0.7rem;">New</span>';
            }
          }
        } else if (currentPendingCount < knownPendingCount) {
             knownPendingCount = currentPendingCount; // Someone else reviewed it
        }
      }
    } catch (err) {
      console.error('Polling error', err);
    }
  }, 10000); // Poll every 10 seconds

</script>

<%- include('partials/footer') %>
