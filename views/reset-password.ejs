<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password - EMS Workspace</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">EMS Workspace</div>
      <div class="auth-subtitle">Reset your account password</div>
    </div>

    <% if (locals.error) { %>
      <div class="alert alert-danger">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <%= error %>
      </div>
    <% } %>

    <form action="/reset-password" method="POST">
      <div class="form-group">
        <label for="email" class="form-label">Email Address</label>
        <input type="email" id="email" name="email" class="form-control" placeholder="name@company.com" required>
      </div>

      <div class="form-group">
        <label for="dob" class="form-label">Date of Birth</label>
        <input type="date" id="dob" name="dob" class="form-control" required>
      </div>

      <div class="form-group">
        <label for="new_password" class="form-label">New Password</label>
        <input type="password" id="new_password" name="new_password" class="form-control" placeholder="Min. 6 characters" required>
      </div>

      <button type="submit" class="btn btn-primary btn-full" style="margin-top: 1rem;">Reset Password</button>
    </form>

    <div class="auth-footer-link">
      Remembered your password? <a href="/login">Sign In</a>
    </div>
  </div>
</body>
</html>
