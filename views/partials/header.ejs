<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>EMS - Employee Management System</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="nav-container">
      <a href="/" class="logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="stroke: currentColor; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
        GradSkills Workspace
      </a>
      
      <% if (locals.user) { %>
        <div class="user-nav-info">
          <div class="user-profile">
            <span class="avatar"><%= user.name.charAt(0).toUpperCase() %></span>
            <div>
              <div style="font-weight: 600; font-size: 0.95rem;"><%= user.name %></div>
              <span class="role-badge role-<%= user.role %>"><%= user.role %></span>
            </div>
          </div>
          <a href="/logout" class="btn-logout">Logout</a>
        </div>
      <% } %>
    </div>
  </header>
  <main class="container">
